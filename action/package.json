{
  "name": "ledgerful-action",
  "version": "1.0.0",
  "description": "GitHub Action for Ledgerful risk analysis on pull requests",
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --conditions=import --outfile=dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src __tests__",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@types/node": "^20.0.0",
    "esbuild": "0.28.1",
    "eslint": "^9.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
